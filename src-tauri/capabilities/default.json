{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "process:allow-restart",
    "updater:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://neon.new/" },
        { "url": "https://console.neon.tech/app/claim*" }
      ]
    }
  ]
}
